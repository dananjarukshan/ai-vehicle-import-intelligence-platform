# ============================================================================
# ENVIRONMENT CONFIGURATION FILE TEMPLATE
# ============================================================================
# IMPORTANT: This is a TEMPLATE file showing what environment variables
# the application needs. 
#
# HOW TO USE THIS FILE:
# 1. Copy this file and rename it to ".env" (in the backend folder)
# 2. Fill in your actual values in the .env file
# 3. NEVER commit .env to git (it contains sensitive data!)
# 4. Only commit .env.example to show what variables are needed
#
# This setup allows different values for different environments:
# - Development (local testing)
# - Testing (test environment)
# - Production (live/deployed application)
# ============================================================================

# NODE_ENV determines which environment the application runs in
# Values: "development" | "testing" | "production"
# - development: Shows detailed error messages, doesn't minimize code
# - testing: Used when running automated tests
# - production: Optimized for speed, minimal error details for security
NODE_ENV=development

# PORT is the number that tells Express which port to listen on
# Think of it like a "door number" for incoming requests
# Common values: 3000 (development), 5000 (alternative), 8080 (alternative)
# Make sure no other application is using this port
PORT=3000

# API_VERSION helps organize and version your API endpoints
# Example: /api/v1/vehicles, /api/v1/users
# This allows you to maintain multiple versions of your API simultaneously
API_VERSION=v1

# DATABASE_URL will store your database connection string
# Format varies by database: 
# - MongoDB: mongodb://username:password@host:port/dbname
# - PostgreSQL: postgresql://user:password@host:port/dbname
# Placeholder for now - configure when you set up your database
DATABASE_URL=mongodb://localhost:27017/ai-vehicle-price-estimation

# JWT_SECRET is a secret key used to sign and verify authentication tokens
# This is CRITICAL for security - use a long, random string in production
# Never share this value with anyone
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# LOG_LEVEL controls how much detail is logged
# Values: "debug" | "info" | "warn" | "error"
# - debug: Most detailed (includes everything)
# - info: General information about application flow
# - warn: Warning messages (something unexpected but not critical)
# - error: Only critical errors
LOG_LEVEL=info
